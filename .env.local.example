# Supabase - copie para .env.local e preencha com os valores do seu projeto
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
# Chave service role (apenas para API routes no servidor; nunca exponha no cliente)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
